SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Voice provider ─────────────────────────────────────────────────────────────
# Leave VOICE_PROVIDER unset to auto-detect from which keys are present below.
# Set to "none" to disable all AI calls (leads saved as "new" and left there).
VOICE_PROVIDER=

# ── Retell AI (retellai.com) ───────────────────────────────────────────────────
RETELL_API_KEY=your_retell_api_key
RETELL_AGENT_ID=your_retell_agent_id
RETELL_FROM_NUMBER=+12503171366

# ── Vapi AI (vapi.ai) ─────────────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id

# ── Bland AI (bland.ai) ───────────────────────────────────────────────────────
BLAND_API_KEY=your_bland_api_key
BLAND_FROM_NUMBER=+12503171366

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173
ADMIN_PASSWORD=change_me_in_production
